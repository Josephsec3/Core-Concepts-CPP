#include <bits/stdc++.h>
using namespace std;

int main(){
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int n; 
    if (!(cin >> n)) return 0;

    vector<int> l(n * 5);
    for (int i = 0; i < n * 5; i++){
        cin >> l[i];
    }
    sort(l.begin(), l.end());
    double sum = 0;
    int count = 0;
    for (int j = n; j < n * 4; j++){
        sum += l[j];
        count++;
    }
    if (count > 0) {
        cout << fixed << setprecision(6) << sum / count << "\n";
    }

    return 0;
}
